    "NateNiteProductionSiteUrlRewriteFunction8648BE8F": {
      "Type": "AWS::CloudFront::Function",
      "Properties": {
        "AutoPublish": true,
        "FunctionCode": "\nfunction handler(event) {\n    var request = event.request;\n    var uri = request.uri;\n\n    // Check if URI ends with '/'\n    if (uri.endsWith('/')) {\n        request.uri += 'index.html';\n    }\n    // Check if URI has no extension (no dot in the last segment)\n    else if (!uri.includes('.')) {\n        request.uri += '/index.html';\n    }\n\n    return request;\n}\n            ",
        "FunctionConfig": {
          "Comment": "Rewrite directory requests to append index.html",
          "Runtime": "cloudfront-js-1.0"
        },
        "Name": "us-east-1NateNiteProductilRewriteFunctionC2258315"
      }
    },
